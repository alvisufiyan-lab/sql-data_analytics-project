## Silver Layer — `dw_silver`

The silver layer contains cleaned and standardised data transformed from the raw bronze layer.
All tables are loaded via a single stored procedure that handles deduplication, null handling,
data type casting, and value normalisation across all 6 source tables (3 CRM + 3 ERP).

### What gets cleaned
| Table | Transformations Applied |
|---|---|
| `crm_customers` | Deduplicated by `cst_key`, trimmed names, normalised gender & marital status, date cast |
| `crm_products` | Deduplicated by `prd_key`, expanded product line codes, derived `prd_end_dt` via LEAD |
| `crm_sales` | Integer dates cast to DATE, recalculated sales = qty × price, negatives/zeros resolved |
| `erp_cust_az12` | Stripped NAS prefix from CID, nullified future birthdates, normalised gender values |
| `erp_loc_a101` | Removed hyphens from CID, standardised country name variants (US/USA → America) |
| `erp_px_cat_g1v2` | Trimmed whitespace, stripped carriage returns from last column |

### Prerequisites
- Bronze layer must be loaded first before calling the silver procedure
- Run the bronze load script manually since `LOAD DATA` cannot run inside a stored procedure

### How to use

**Step 1 — Load bronze (run as plain script)**
```sql
-- SET GLOBAL local_infile = 1;
-- Then run the full bronze load script
```

**Step 2 — Load silver (call the procedure)**
```sql
-- CALL dw_silver.load_silver();
```

The procedure automatically truncates each silver table before inserting,
making it safe to re-run at any time without creating duplicates.

DELIMITER $$

CREATE PROCEDURE dw_silver.load_silver()
BEGIN

    -- Table 1
    TRUNCATE TABLE dw_silver.crm_customers;
    INSERT INTO dw_silver.crm_customers (
        cst_id, cst_key, cst_firstname, cst_lastname,
        cst_marital_status, cst_gndr, cst_create_date, dw_create_date
    )
    SELECT
        cst_id,
        cst_key,
        NULLIF(TRIM(cst_firstname), '')                                     AS cst_firstname,
        NULLIF(TRIM(cst_lastname), '')                                      AS cst_lastname,
        CASE
            WHEN UPPER(TRIM(cst_marital_status)) = 'M' THEN 'Married'
            WHEN UPPER(TRIM(cst_marital_status)) = 'S' THEN 'Single'
            ELSE 'N/A'
        END                                                                 AS cst_marital_status,
        CASE
            WHEN UPPER(TRIM(cst_gndr)) = 'M' THEN 'Male'
            WHEN UPPER(TRIM(cst_gndr)) = 'F' THEN 'Female'
            ELSE 'N/A'
        END                                                                 AS cst_gndr,
        CASE
            WHEN NULLIF(TRIM(cst_create_date), '') IS NULL THEN NULL
            ELSE STR_TO_DATE(cst_create_date, '%d/%m/%Y')
        END                                                                 AS cst_create_date,
        CURRENT_TIMESTAMP()                                                 AS dw_create_date
    FROM (
        SELECT *,
        ROW_NUMBER() OVER (PARTITION BY cst_key ORDER BY cst_create_date DESC) AS flag
        FROM dw_bronze.crm_customers
        WHERE cst_id != 0
    ) t
    WHERE flag = 1;

    -- Table 2
    TRUNCATE TABLE dw_silver.crm_products;
    INSERT INTO dw_silver.crm_products (
        prd_id, prd_key, prd_nm, prd_cost,
        prd_line, prd_start_dt, prd_end_dt, dw_create_date
    )
    SELECT
        prd_id,
        prd_key,
        COALESCE(NULLIF(TRIM(prd_nm), ''), 'N/A')                          AS prd_nm,
        COALESCE(prd_cost, 0)                                               AS prd_cost,
        CASE
            WHEN UPPER(TRIM(prd_line)) = 'R' THEN 'Road'
            WHEN UPPER(TRIM(prd_line)) = 'M' THEN 'Mountain'
            WHEN UPPER(TRIM(prd_line)) = 'S' THEN 'Other Sales'
            WHEN UPPER(TRIM(prd_line)) = 'T' THEN 'Touring'
            ELSE 'N/A'
        END                                                                 AS prd_line,
        STR_TO_DATE(NULLIF(TRIM(prd_start_dt), ''), '%Y-%m-%d')            AS prd_start_dt,
        DATE_SUB(
            LEAD(STR_TO_DATE(NULLIF(TRIM(prd_start_dt), ''), '%Y-%m-%d'))
            OVER (PARTITION BY prd_key ORDER BY STR_TO_DATE(NULLIF(TRIM(prd_start_dt), ''), '%Y-%m-%d')),
            INTERVAL 1 DAY
        )                                                                   AS prd_end_dt,
        CURRENT_TIMESTAMP()                                                 AS dw_create_date
    FROM dw_bronze.crm_products
    ORDER BY prd_id;

    -- Table 3
    TRUNCATE TABLE dw_silver.crm_sales;
    INSERT INTO dw_silver.crm_sales (
        sls_ord_num, sls_prd_key, sls_cust_id, sls_order_dt,
        sls_ship_dt, sls_due_dt, sls_sales, sls_quantity, sls_price, dw_create_date
    )
    SELECT
        sls_ord_num,
        sls_prd_key,
        sls_cust_id,
        CASE
            WHEN sls_order_dt = 0 OR LENGTH(sls_order_dt) < 8 OR sls_order_dt IS NULL THEN NULL
            ELSE CAST(CAST(sls_order_dt AS CHAR) AS DATE)
        END                                                                 AS sls_order_dt,
        CASE
            WHEN sls_ship_dt = 0 OR sls_ship_dt IS NULL THEN NULL
            ELSE CAST(CAST(sls_ship_dt AS CHAR) AS DATE)
        END                                                                 AS sls_ship_dt,
        CASE
            WHEN sls_due_dt = 0 OR sls_due_dt IS NULL THEN NULL
            ELSE CAST(CAST(sls_due_dt AS CHAR) AS DATE)
        END                                                                 AS sls_due_dt,
        CASE
            WHEN sls_sales IS NULL OR sls_sales <= 0 OR sls_sales != sls_quantity * ABS(sls_price)
            THEN sls_quantity * ABS(sls_price)
            ELSE sls_sales
        END                                                                 AS sls_sales,
        sls_quantity,
        CASE
            WHEN sls_price IS NULL OR sls_price <= 0
            THEN sls_sales / NULLIF(sls_quantity, 0)
            ELSE sls_price
        END                                                                 AS sls_price,
        CURRENT_TIMESTAMP()                                                 AS dw_create_date
    FROM dw_bronze.crm_sales;

    -- Table 4
    TRUNCATE TABLE dw_silver.erp_cust_az12;
    INSERT INTO dw_silver.erp_cust_az12 (cid, bdate, gen)
    SELECT
        CASE
            WHEN cid LIKE 'NAS%' THEN SUBSTRING(cid, 4)
            ELSE cid
        END                                                                 AS cid,
        CASE
            WHEN bdate > CURDATE() OR bdate IS NULL THEN NULL
            ELSE bdate
        END                                                                 AS bdate,
        CASE
            WHEN UPPER(TRIM(REPLACE(gen, '\r', ''))) IN ('FEMALE', 'F') THEN 'Female'
            WHEN UPPER(TRIM(REPLACE(gen, '\r', ''))) IN ('MALE',   'M') THEN 'Male'
            ELSE 'N/A'
        END                                                                 AS gen
    FROM dw_bronze.erp_cust_az12;

    -- Table 5
    TRUNCATE TABLE dw_silver.erp_loc_a101;
    INSERT INTO dw_silver.erp_loc_a101 (cid, cntry)
    SELECT
        REPLACE(TRIM(cid), '-', '')                                         AS cid,
        CASE
            WHEN TRIM(REPLACE(REPLACE(cntry, '\r', ''), '\n', ''))
                 IN ('US', 'USA', 'United States')                          THEN 'America'
            WHEN TRIM(REPLACE(REPLACE(cntry, '\r', ''), '\n', ''))
                 IN ('DE', 'Germany')                                       THEN 'Germany'
            WHEN cntry IS NULL                                              THEN NULL
            ELSE TRIM(REPLACE(REPLACE(cntry, '\r', ''), '\n', ''))
        END                                                                 AS cntry
    FROM dw_bronze.erp_loc_a101;

    -- Table 6
    TRUNCATE TABLE dw_silver.erp_px_cat_g1v2;
    INSERT INTO dw_silver.erp_px_cat_g1v2 (id, cat, subcat, maintenance)
    SELECT
        NULLIF(TRIM(id),          '')                                       AS id,
        NULLIF(TRIM(cat),         '')                                       AS cat,
        NULLIF(TRIM(subcat),      '')                                       AS subcat,
        NULLIF(TRIM(REPLACE(maintenance, '\r', '')), '')                    AS maintenance
    FROM dw_bronze.erp_px_cat_g1v2;

END$$
DELIMITER ;


SET GLOBAL local_infile = 1;
CALL dw_silver.load_silver();
